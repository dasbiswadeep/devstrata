<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.devstrata.headroom-watchdog</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-c</string>
        <string>PATH=/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin; &lt;PATH-TO-DEVSTRATA&gt;/scripts/headroom-watchdog.sh</string>
    </array>

    <key>StartInterval</key>
    <integer>120</integer>

    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/tmp/devstrata-watchdog-launchd.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/devstrata-watchdog-launchd.log</string>
</dict>
</plist>