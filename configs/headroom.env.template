# headroom.env — copy to your project root, edit, gitignore it.
# All LLM provider config lives here. Headroom routes everything.
# One swap here adapts every layer of the stack.
#
# IMPORTANT — Graphify needs an LLM key for non-code files (docs, PDFs, images):
#   If you run `graphify .` and see "no LLM API key found", set one of the
#   API keys below. A code-only corpus needs no key, but a README.md counts
#   as a doc file — so most projects need a key set.
#   Ollama-only users: Graphify can use Ollama for extraction if you set
#   GRAPHiFY_OLLAMA_URL=http://localhost:11434 (check upstream docs).

# ── Choose ONE primary backend ──────────────────────────────────────────────

# Option A: Ollama (local, private, free)
export OLLAMA_BASE_URL=http://localhost:11434
export OLLAMA_MODEL=qwen2.5-coder:14b
export OPENAI_BASE_URL=http://localhost:11434/v1
export OPENAI_API_KEY=ollama

# Option B: Claude (best reasoning) — uncomment to use
# export ANTHROPIC_API_KEY=sk-ant-...
# Models: claude-opus-4-7 (orchestration) / claude-sonnet-4-6 (daily) / claude-haiku-4-5 (fast)

# Option C: OpenAI — uncomment to use
# export OPENAI_API_KEY=sk-...

# Option D: Gemini — uncomment to use
# export GEMINI_API_KEY=...

# Option E: DeepSeek — uncomment to use
# export DEEPSEEK_API_KEY=...

# ── Headroom proxy settings ─────────────────────────────────────────────────
export HEADROOM_PROXY_PORT=8787

# M-series Mac GPU acceleration
export HEADROOM_OUTPUT_SHAPER=1
export HEADROOM_EMBEDDER_RUNTIME=pytorch_mps

# Audit log — all tool outputs logged here ( SECURITY.md T2 mitigation)
export HEADROOM_AUDIT_LOG=/tmp/headroom-audit.log